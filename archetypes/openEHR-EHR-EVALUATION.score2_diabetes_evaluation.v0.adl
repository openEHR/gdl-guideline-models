definition
	EVALUATION[at0000] matches {    -- SCORE2_Diabetes Evaluation
		data matches {
			ITEM_TREE[at0001] matches {    -- Item tree
				items cardinality matches {0..*; unordered} matches {
					ELEMENT[at0002] occurrences matches {0..1} matches {    -- Percentage 10-year risk of CVD
						value matches {
							DV_PROPORTION matches {
								type matches {2}
							}
						}
					}
					ELEMENT[at0003] occurrences matches {0..1} matches {    -- Patients <50 years old
						value matches {
							1|[local::at0004],
							2|[local::at0005],
							3|[local::at0006]
						}
					}
					ELEMENT[at0007] occurrences matches {0..1} matches {    -- Patients 50-69 years old
						value matches {
							1|[local::at0008],
							2|[local::at0009],
							3|[local::at0010]
						}
					}
				}
			}
		}
	}

