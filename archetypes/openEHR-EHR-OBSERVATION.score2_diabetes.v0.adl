				["at0010"] = <
					text = <"Total cholesterol">
					description = <"Apply ctchol = tchol – 6">
				>
				["at0011"] = <
					text = <"HDL cholesterol">
					description = <"Apply  chdl = (hdl – 1.3)/0.5">
				>
				["at0014"] = <
					text = <"HgbA1c">
					description = <"Apply : ca1c = (a1c – 31)/9.34">
				>
				["at0015"] = <
