{"id":"Braden.v0.0.4","gdl_version":"2.0","concept":"gt0001","language":{"original_language":"ISO_639-1::en"},"description":{"original_author":{"name":"Therese Lindberg","email":"therese.lindberg@cambio.se","organisation":"Cambio CDS","date":"2020-06-30"},"lifecycle_state":"Author draft","details":{"en":{"id":"en","purpose":"To calculate and interpret the total sum for Braden score.","keywords":["braden score","pressure","ulcers","risk","sensory perception","moisture","activity","mobility","nutrition","friction","shear"],"use":"The Braden score is used in immobile or chronically hospitalized patients to identify patients who are at a risk of developing pressure ulcers. The score is calculated based on six different areas: activity, moisture, mobility, nutrition, sensory perception, and friction and shear.\nThese six areas form the input fields. Fill in all the input fiels to calculate the total score and its interpretation.","copyright":"Use © Cambio CDS","misuse":"The score should not be used by itself, but should be used in conjunction with clinical assessmentas it does not capture all risk factors of developing pressure ulcers. The score should not be calculated only once, periodic assessments are necessary."}},"other_details":{"references":"1. Bergstrom N, Braden BJ, Laguzza A, Holman V. The Braden scale for predicting pressure sore risk. Nurs Res. 1987;36(4):205-10.","en":"Braden score identifies patients at risk of developing pressure ulcers."},"other_contributors":["Shweta Prasad Ghaisas"]},"definition":{"data_bindings":{"gt0002":{"id":"gt0002","type":"INPUT","model_id":"openEHR-EHR-EVALUATION.braden_score_pressure_ulcers.v0","template_id":"openEHR-EHR-EVALUATION.braden_score_pressure_ulcers.v0","elements":{"gt0005":{"id":"gt0005","path":"/data[at0001]/items[at0018]"},"gt0004":{"id":"gt0004","path":"/data[at0001]/items[at0013]"},"gt0006":{"id":"gt0006","path":"/data[at0001]/items[at0019]"},"gt0007":{"id":"gt0007","path":"/data[at0001]/items[at0020]"},"gt0008":{"id":"gt0008","path":"/data[at0001]/items[at0008]"},"gt0003":{"id":"gt0003","path":"/data[at0001]/items[at0021]"}}},"gt0009":{"id":"gt0009","type":"OUTPUT","model_id":"openEHR-EHR-EVALUATION.braden_score_pressure_ulcers.v0","template_id":"openEHR-EHR-EVALUATION.braden_score_pressure_ulcers.v0","elements":{"gt0010":{"id":"gt0010","path":"/data[at0001]/items[at0002]"},"gt0011":{"id":"gt0011","path":"/data[at0001]/items[at0007]"}}}},"rules":{"gt0012":{"id":"gt0012","priority":5,"when":["$gt0003|Friction and shear|!=null","$gt0004|Moisture|!=null","$gt0005|Activity|!=null","$gt0006|Mobility|!=null","$gt0007|Nutrition |!=null","$gt0008|Sensory perception|!=null"],"then":["$gt0011|Braden Score|.magnitude=$gt0003.value+$gt0004.value+$gt0006.value+$gt0007.value+$gt0008.value+$gt0005.value"]},"gt0013":{"id":"gt0013","priority":4,"when":["$gt0011|Braden Score|.magnitude<=12"],"then":["$gt0010|Risk Group|=local::at0006|High|"]},"gt0014":{"id":"gt0014","priority":3,"when":["$gt0011|Braden Score|.magnitude>=13","$gt0011|Braden Score|.magnitude<=15"],"then":["$gt0010|Risk Group|=local::at0005|Moderate|"]},"gt0015":{"id":"gt0015","priority":2,"when":["$gt0011|Braden Score|.magnitude>=16","$gt0011|Braden Score|.magnitude<=17"],"then":["$gt0010|Risk Group|=local::at0004|Mild|"]},"gt0016":{"id":"gt0016","priority":1,"when":["$gt0011|Braden Score|.magnitude>=18"],"then":["$gt0010|Risk Group|=local::at0003|Average|"]}}},"ontology":{"term_definitions":{"en":{"id":"en","terms":{"gt0001":{"id":"gt0001","text":"Braden score","description":"Braden score: An assessment score to identify patients at risk of developing pressure ulcers."},"gt0003":{"id":"gt0003","text":"Friction and shear"},"gt0004":{"id":"gt0004","text":"Moisture"},"gt0005":{"id":"gt0005","text":"Activity"},"gt0006":{"id":"gt0006","text":"Mobility"},"gt0007":{"id":"gt0007","text":"Nutrition "},"gt0008":{"id":"gt0008","text":"Sensory perception"},"gt0010":{"id":"gt0010","text":"Risk Group"},"gt0011":{"id":"gt0011","text":"Braden Score"},"gt0012":{"id":"gt0012","text":"Calculate Braden Score"},"gt0013":{"id":"gt0013","text":"Risk Group - High"},"gt0014":{"id":"gt0014","text":"Risk Group - Moderate"},"gt0015":{"id":"gt0015","text":"Risk Group - Mild"},"gt0016":{"id":"gt0016","text":"Risk Group - Average"},"gt0002":{"id":"gt0002","text":"openEHR-EHR-EVALUATION.braden_score_pressure_ulcers.v0"},"gt0009":{"id":"gt0009","text":"openEHR-EHR-EVALUATION.braden_score_pressure_ulcers.v0"}}}}}}