{"id":"Horowitz_Index.v0.0.1","gdl_version":"2.0","concept":"gt0001","language":{"original_language":"ISO_639-1::en"},"description":{"original_author":{"name":"Henrik Honkanen","email":"henrik.honkanen@stud.ki.se","organisation":"Cambio CDS","date":"2020-07-13"},"lifecycle_state":"Author draft","details":{"en":{"id":"en","purpose":"To calculate and assess lung function by comparing PaO₂ and FiO in intubated patients.","keywords":["lung function","COVID-19","Horowitz index","ARDS","FiO2","PaO2","P/F ratio"],"use":"The P/F ratio should be used in intubated patients where arterial oxygen partial pressure (PaO₂) and fractional inspired oxygen (FiO₂) can be measured accurately, as estimated values may lead to incorrect interpretation.\n\nIt is primarily applied in patients with suspected or confirmed acute respiratory distress syndrome (ARDS). \n\nFill in all the input fields, which are- PaO₂ and FiO₂- to receive a total score and interpretation.\n","misuse":"Not to be used in non-intubated patients or when accurate measurements of PaO₂ and FiO₂ are unavailable. \n\nNot to be used as a substitute for the A-a gradient, as it cannot differentiate between hypoventilation and V/Q mismatch. \n\nNot applicable for conditions unrelated to respiratory impairment or ARDS assessment. \n\n Not applicable in cases where PaCO₂ is abnormal, where a shunt is present, or where accurate arterial blood gas (ABG) analysis cannot be performed.","copyright":"© Cambio CDS"}},"other_details":{"references":"Horovitz JH, Carrico CJ, Shires GT. Pulmonary response to major injury. Arch Surg. 1974 Mar;108(3):349-55. doi: 10.1001/archsurg.1974.01350270079014. PMID: 4813333.","en":"Horowitz Index (P/F Ratio) is an assessment used to evaluate lung function."},"other_contributors":["Umiah Gohar"]},"definition":{"data_bindings":{"gt0002":{"id":"gt0002","model_id":"openEHR-EHR-OBSERVATION.horowitz_index_for_lung_function_p_f_ratio.v0","template_id":"openEHR-EHR-OBSERVATION.horowitz_index_for_lung_function_p_f_ratio.v0","type":"INPUT","elements":{"gt0003":{"id":"gt0003","path":"/data[at0001]/events[at0002]/data[at0003]/items[at0011]"},"gt0004":{"id":"gt0004","path":"/data[at0001]/events[at0002]/data[at0003]/items[at0012]"},"gt0005":{"id":"gt0005","path":"/data[at0001]/events[at0002]/data[at0003]/items[at0006]"}}},"gt0006":{"id":"gt0006","model_id":"openEHR-EHR-OBSERVATION.horowitz_index_for_lung_function_p_f_ratio.v0","template_id":"openEHR-EHR-OBSERVATION.horowitz_index_for_lung_function_p_f_ratio.v0","type":"OUTPUT","elements":{"gt0007":{"id":"gt0007","path":"/data[at0001]/events[at0002]/data[at0003]/items[at0018]"},"gt0018":{"id":"gt0018","path":"/data[at0001]/events[at0002]/data[at0003]/items[at0024]"},"gt0019":{"id":"gt0019","path":"/data[at0001]/events[at0002]/data[at0003]/items[at0019]"},"gt0020":{"id":"gt0020","path":"/data[at0001]/events[at0002]/data[at0003]/items[at0013]"}}}},"rules":{"gt0010":{"id":"gt0010","priority":6,"when":["$gt0003|PaO2|.unit=='kPa'","$gt0003|PaO2|!=null","$gt0004|FiO2|!=null"],"then":["$gt0007|Calculate Horowitz Index (P/F ratio)|.precision=1","$gt0007|Calculate Horowitz Index (P/F ratio)|.magnitude=($gt0003.magnitude*7.501)/($gt0004.magnitude/100)","$gt0007|Calculate Horowitz Index (P/F ratio)|.unit='mm[Hg]'"]},"gt0013":{"id":"gt0013","priority":5,"when":["$gt0003|PaO2|.unit=='mm[Hg]'","$gt0003|PaO2|!=null","$gt0004|FiO2|!=null"],"then":["$gt0007|Calculate Horowitz Index (P/F ratio)|.precision=1","$gt0007|Calculate Horowitz Index (P/F ratio)|.magnitude=$gt0003.magnitude/($gt0004.magnitude/100)","$gt0007|Calculate Horowitz Index (P/F ratio)|.unit='mm[Hg]'"]},"gt0017":{"id":"gt0017","priority":4,"when":["$gt0007|Calculate Horowitz Index (P/F ratio)|<=100,mm[Hg]"],"then":["$gt0018|Severity of ARDS|=local::at0028|Severe ARDS|","$gt0019|Mortality interpretation|=local::at0023|Mortality 45%|","$gt0020|Horowitz index interpretation|=local::at0017|Horowitz Index (P/F Ratio) ≤100mmHg|"]},"gt0016":{"id":"gt0016","priority":3,"when":["$gt0007|Calculate Horowitz Index (P/F ratio)|<=200,mm[Hg]","$gt0007|Calculate Horowitz Index (P/F ratio)|>100,mm[Hg]"],"then":["$gt0018|Severity of ARDS|=local::at0027|Moderate ARDS|","$gt0019|Mortality interpretation|=local::at0022|Mortality 32%|","$gt0020|Horowitz index interpretation|=local::at0016|Horowitz Index (P/F Ratio) >100-200mmHg|"]},"gt0015":{"id":"gt0015","priority":2,"when":["$gt0007|Calculate Horowitz Index (P/F ratio)|<=300,mm[Hg]","$gt0007|Calculate Horowitz Index (P/F ratio)|>200,mm[Hg]"],"then":["$gt0018|Severity of ARDS|=local::at0026|Mild ARDS|","$gt0019|Mortality interpretation|=local::at0021|Mortality 27%|","$gt0020|Horowitz index interpretation|=local::at0015|Horowitz Index (P/F Ratio) >200-300mmHg|"]},"gt0014":{"id":"gt0014","priority":1,"when":["$gt0007|Calculate Horowitz Index (P/F ratio)|>300,mm[Hg]"],"then":["$gt0018|Severity of ARDS|=local::at0025|Not ARDS|","$gt0019|Mortality interpretation|=local::at0020|Mortality undefined|","$gt0020|Horowitz index interpretation|=local::at0014|Horowitz Index (P/F Ratio) >300mmHg|"]}}},"ontology":{"term_definitions":{"en":{"id":"en","terms":{"gt0001":{"id":"gt0001","text":"Horowitz Index  score for Lung Function (P/F Ratio)","description":"An assessment score used to evaluate lung function, particularly in intubated patients, by comparing the arterial oxygen partial pressure (PaO₂) to the fractional inspired oxygen (FiO₂). It is commonly applied to assess lung function  and risk stratification of patients with acute respiratory distress syndrome (ARDS)."},"gt0003":{"id":"gt0003","text":"PaO2","description":"*"},"gt0004":{"id":"gt0004","text":"FiO2","description":"*"},"gt0005":{"id":"gt0005","text":"Is this a COVID-19 patient?","description":"*"},"gt0007":{"id":"gt0007","text":"Calculate Horowitz Index (P/F ratio)","description":"*Horowitz Index (P/F Ratio), mmHg = PaO2 / FiO2"},"gt0008":{"id":"gt0008","text":"Horowitz index interpretation","description":"*"},"gt0009":{"id":"gt0009","text":"Calculate Horowitz ratio"},"gt0010":{"id":"gt0010","text":"Calculate Horowitz Index (P/F ratio) kPa"},"gt0012":{"id":"gt0012","text":"PaO2","description":"PaO2"},"gt0013":{"id":"gt0013","text":"Calculate Horowitz index (P/F ratio) mmHg"},"gt0014":{"id":"gt0014","text":"Horowitz ratio interpretation >300"},"gt0015":{"id":"gt0015","text":"Horowitz ratio interpretation 200-300"},"gt0016":{"id":"gt0016","text":"Horowitz ratio interpretation >100-200"},"gt0017":{"id":"gt0017","text":"Horowitz ratio interpretation <=100"},"gt0018":{"id":"gt0018","text":"Severity of ARDS","description":"*"},"gt0019":{"id":"gt0019","text":"Mortality interpretation","description":"*"},"gt0020":{"id":"gt0020","text":"Horowitz index interpretation","description":"*"},"gt0002":{"id":"gt0002","text":"openEHR-EHR-OBSERVATION.horowitz_index_for_lung_function_p_f_ratio.v0"},"gt0006":{"id":"gt0006","text":"openEHR-EHR-OBSERVATION.horowitz_index_for_lung_function_p_f_ratio.v0"}}}}}}